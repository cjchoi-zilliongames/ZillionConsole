[
  {
    "origin": [
      "https://firebase-storage-admin.vercel.app",
      "https://zillion-console.vercel.app",
      "http://localhost:3000",
      "http://localhost:3001"
    ],
    "method": ["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD", "PATCH"],
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "User-Agent",
      "x-goog-resumable",
      "x-goog-upload-protocol",
      "x-goog-upload-status",
      "x-goog-upload-command",
      "x-goog-upload-offset",
      "x-goog-upload-file-name",
      "x-goog-upload-url",
      "x-goog-upload-chunk-granularity",
      "x-firebase-storage-version",
      "Cache-Control",
      "ETag"
    ],
    "maxAgeSeconds": 3600
  }
]
