rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /log/{uid} {
      allow read: if false;
      allow write: if
        // true;
       request.resource.data.FS_UID == request.auth.uid;
    }

    match /trigger/trigger {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if true;
      allow write: if
        request.resource.data.UserInfo.FS_UID == request.auth.uid
        &&
        (
                   !exists(/databases/$(database)/documents/users/$(uid))
          ||
          resource.data == null
          ||
          !(resource.data.keys().hasAny(['UserInfo']))
          ||
          !(resource.data.UserInfo.keys().hasAny(['LastWriteAt']))
          ||
          request.resource.data.UserInfo.LastWriteAt
            - resource.data.UserInfo.LastWriteAt > duration.value(10, 'ms')
        );
    }

    // 차트(chart)·우편(postbox) 등 시그널 — 문서 ID 전체에 동일 정책
    match /signals/{signalId} {
      allow read: if true;
      allow write: if true;
    }

    // 스펙 작업 히스토리 — Admin SDK + REST API만 사용. 브라우저 직접 접근 불가.
    match /specHistory/{recordId} {
      allow read, write: if false;
    }

    // 운영 공지 — Admin SDK + 툴 API만 사용. (클라 앱은 별도 규칙 또는 API로 노출)
    match /notices/{noticeId} {
      allow read, write: if false;
    }

  }
}
